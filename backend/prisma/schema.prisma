// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderType {
  MARKET
  LIMIT
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
}

enum FillType {
  MAKER
  TAKER
}

model User {
  id              Int      @id @default(autoincrement())
  username        String   @unique
  password        String

  orders          Order[]
  fills           Fill[]
}

model Asset {
  id            Int       @id @default(autoincrement())
  name          String
  symbol        String    @unique
}

model Order {
  id                  Int           @id @default(autoincrement())

  userId              Int
  user                User          @relation(fields: [userId], references: [id])

  market              String

  price               BigInt?

  quantity            BigInt
  filledQuantity      BigInt
  remainingQuantity   BigInt

  type                OrderType
  side                OrderSide

  status              OrderStatus

  createdAt           DateTime      @default(now())

  fills               Fill[]

}

model Fill {
  id                  Int          @id @default(autoincrement())
  
  quantity            BigInt

  side                OrderSide

  type                FillType

  userId              Int
  user                User          @relation(fields: [userId], references: [id])

  price               BigInt

  market              String

  orderId             Int
  order               Order         @relation(fields: [orderId], references: [id])

  createdAt           DateTime      @default(now())
}
